# .gitignore

# Video file (too large for GitHub)
data/traffic.mp4
data/*.mp4

# YOLO model weights (auto-downloaded on first run)
yolov8n.pt
*.pt

# Runtime logs
logs/*.csv

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environment
venv/
env/

# AWS key (NEVER push this)
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env